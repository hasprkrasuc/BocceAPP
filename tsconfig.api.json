{
  // Vercel gradi api/ brez preverjanja tipov, osnovni tsconfig.json pa vključuje samo src.
  // Ta konfiguracija zato ločeno tipno preveri strežniške funkcije (npm run typecheck:api).
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],
    "jsx": "preserve"
  },
  "include": ["api", "src/lib/playerImport/types.ts"]
}
